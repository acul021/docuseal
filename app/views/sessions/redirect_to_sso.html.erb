<div class="max-w-lg mx-auto px-2 text-center mt-16">
  <p class="text-gray-600 mb-4"><%= t('redirecting_to_sso') %></p>
  <%= form_tag user_oidc_omniauth_authorize_path, method: :post, id: 'sso-redirect-form', data: { turbo: false } do %>
  <% end %>
  <% unless local_assigns[:hide_skip] || (@force_sso_enabled if defined?(@force_sso_enabled)) %>
    <p class="text-xs text-gray-500 mt-6">
      <%= link_to t('sso_sign_in_with_password_instead'), new_user_session_path(sso: 'skip'), class: 'underline' %>
    </p>
  <% end %>
</div>
<script nonce="<%= content_security_policy_nonce %>">document.getElementById('sso-redirect-form').submit();</script>
